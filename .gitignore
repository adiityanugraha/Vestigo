# ============================================================
# Root .gitignore (monorepo: frontend/ + backend/)
# Frontend punya .gitignore sendiri di frontend/.gitignore
# File ini fokus ke backend Python + hal umum.
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/
backend/venv/

# Packaging / build
*.egg-info/
.eggs/
dist/
build/
*.egg

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Secrets / environment ---
# JANGAN commit kredensial DB/Redis. Hanya .env.example yang boleh di-push.
.env
.env.*
!.env.example
!**/.env.example

# --- Misc ---
.DS_Store
*.log
