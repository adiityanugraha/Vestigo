# ============================================================
# Pocket Screener Backend — contoh environment variables
# Salin file ini menjadi .env lalu isi nilai aslinya.
#   cp .env.example .env        (atau copy di Windows)
# .env TIDAK akan ter-commit (lihat .gitignore root).
# ============================================================

# Metadata
ENVIRONMENT=development

# PostgreSQL (Day 2) — dari Supabase / Neon
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Redis (Day 4) — dari Upstash
# Format: rediss://default:PASSWORD@HOST:6379
REDIS_URL=

# CORS — origin frontend yang boleh akses API (pisahkan dengan koma)
CORS_ORIGINS=http://localhost:3000

# --- Phase 5: lapisan AI (LLM + embedding) ---
# Google Gemini API key (free tier) — buat di https://aistudio.google.com/apikey
# Bila kosong, semua fitur AI Phase 5 nonaktif (aman-gagal). JANGAN commit nilainya.
GEMINI_API_KEY=
# Override opsional (default sudah masuk akal untuk free tier):
# LLM_MODEL=gemini-2.5-flash
# EMBEDDING_MODEL=text-embedding-004
